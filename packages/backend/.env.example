
# Server Configuration
PORT=3001
NODE_ENV=development

# Security
# IMPORTANTE: Cambiar en producción por una clave segura de al menos 32 caracteres
PO_AI_MASTER_KEY=cambiar-en-produccion-clave-segura-32chars
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

# Jira Configuration
# Obtén tu API token en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token

# Figma Configuration (opcional)
FIGMA_ACCESS_TOKEN=your-figma-token

# Datadog Configuration (opcional)
# Scopes requeridos: dashboards_read, monitors_read, incidents_read, logs_read_data, slos_read
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# LLM Configuration
# Proveedores soportados: gemini, openai, anthropic
LLM_PROVIDER=gemini
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gemini-2.0-flash

# Storage paths (por defecto: ~/.po-ai/)
# CREDENTIAL_STORE_PATH=~/.po-ai/credentials.json
# WORKSPACE_DIR=~/.po-ai/workspaces
# HISTORY_DIR=~/.po-ai/history
